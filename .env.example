# @author BenjaminDTS & Carlos Vico
# .env.example — Plantilla de variables de entorno del Proyecto Scraping
# Copiar como .env.development / .env.staging / .env.production y rellenar.
# ¡NUNCA subir archivos .env reales al repositorio!

# ==========================================
# ENTORNO
# ==========================================
APP_ENV=development           # development | staging | production
APP_DEBUG=true                # true solo en development
SECRET_KEY=cambia-esto-en-produccion

# ==========================================
# API
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# REDIS / CELERY
# ==========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==========================================
# SCRAPER — NAVEGADOR
# ==========================================
# Tipo de navegador: chrome | opera | edge | brave | chromium
BROWSER_TYPE=chrome
# Ruta al ejecutable del navegador (obligatoria, nunca hardcodeada en código)
BROWSER_BINARY_PATH=/usr/bin/google-chrome
# Modo headless: true en producción/CI, false para depurar
BROWSER_HEADLESS=true
# Versión principal de Chromium del navegador.
# Requerida para Opera y Brave (su versión de app ≠ versión interna de Chromium).
# Para Chrome/Chromium/Edge se puede dejar vacío — se auto-detecta.
# Cómo encontrarla: opera://about o brave://version → "Versión de Chromium" → número principal.
BROWSER_VERSION_MAIN=
# Segundos máximos de espera de Selenium
BROWSER_TIMEOUT=15

# ==========================================
# SCRAPER — MOTOR DE BÚSQUEDA
# ==========================================
# Motor de búsqueda de imágenes: bing | google | duckduckgo
SEARCH_ENGINE=bing

# ==========================================
# SCRAPER — BÚSQUEDA
# ==========================================
# Número de imágenes a buscar por producto
IMAGES_PER_PRODUCT=5
# Tamaño mínimo aceptable de imagen (px)
IMAGE_MIN_WIDTH=200
IMAGE_MIN_HEIGHT=200
# Tamaño de redimensionado final (px)
IMAGE_RESIZE_WIDTH=800
IMAGE_RESIZE_HEIGHT=800
# Número de workers de descarga simultáneos
DOWNLOAD_WORKERS=4
# Timeout HTTP para descarga de imágenes (segundos)
DOWNLOAD_TIMEOUT=10

# ==========================================
# ALMACENAMIENTO
# ==========================================
# Backend: local | s3 | azure
STORAGE_BACKEND=local
# Directorio raíz (solo si STORAGE_BACKEND=local)
OUTPUT_DIR=imagenes_descargadas
# Tiempo de vida de los archivos de trabajo en segundos (24h por defecto)
FILE_TTL_SECONDS=86400

# ── AWS S3 (solo si STORAGE_BACKEND=s3) ──────────────────────────────────────
AWS_S3_BUCKET=
AWS_S3_PREFIX=harvist
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Azure Blob (solo si STORAGE_BACKEND=azure) ───────────────────────────────
AZURE_CONTAINER=
AZURE_BLOB_PREFIX=harvist
AZURE_CONNECTION_STRING=

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=DEBUG               # ERROR | WARN | INFO | DEBUG
LOG_DIR=logs
LOG_ROTATION=100 MB
LOG_RETENTION=7 days

# ==========================================
# IA — FASE 5 (opcional, dejar vacío para deshabilitar)
# ==========================================
ENABLE_AI_DESCRIPTIONS=false
GROK_API_KEY=
GROK_API_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta
GROK_TIMEOUT=30
GROK_MAX_RETRIES=3
