# @author BenjaminDTS & Carlos Vico
# .env.example — Plantilla de variables de entorno del Proyecto Scraping
# Copiar como .env.development / .env.staging / .env.production y rellenar.
# ¡NUNCA subir archivos .env reales al repositorio!
 
# ==========================================
# ENTORNO
# ==========================================
APP_ENV=development           # development | staging | production
APP_DEBUG=true                # true solo en development
SECRET_KEY=cambia-esto-en-produccion
 
# ==========================================
# API
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
 
# ==========================================
# REDIS / CELERY
# ==========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
 
# ==========================================
# SCRAPER — NAVEGADOR
# ==========================================
# Tipo de navegador: chrome | opera | edge | brave | chromium
BROWSER_TYPE=chrome

# Ruta al ejecutable del navegador.
# Chrome/Chromium: dejar vacío para auto-detección (recomendado).
# Opera/Brave/Edge: ruta obligatoria al ejecutable.
#
# Ejemplos por navegador y OS:
#
# -- Chrome (Windows) — dejar vacío para auto-detección:
BROWSER_BINARY_PATH=
#
# -- Chrome ruta explícita (Windows):
# BROWSER_BINARY_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#
# -- Opera GX (Windows) — BenjaminDTS:
# BROWSER_TYPE=opera
# BROWSER_BINARY_PATH=C:\Users\Usuario\AppData\Local\Programs\Opera GX\opera.exe
# BROWSER_VERSION_MAIN=134
#
# -- Edge (Windows):
# BROWSER_TYPE=edge
# BROWSER_BINARY_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
#
# -- Brave (Windows):
# BROWSER_TYPE=brave
# BROWSER_BINARY_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
# BROWSER_VERSION_MAIN=134

# Modo headless: true en producción/CI, false para depurar
BROWSER_HEADLESS=false
# Versión principal de Chromium (solo requerida para opera | brave — uc la necesita)
BROWSER_VERSION_MAIN=
# Segundos máximos de espera de Selenium
BROWSER_TIMEOUT=15
 
# ==========================================
# SCRAPER — MOTOR DE BÚSQUEDA
# ==========================================
# Motor de búsqueda de imágenes: bing | google | duckduckgo
SEARCH_ENGINE=bing
# Si true, en modo EAN se hace primero una búsqueda web exacta en Google
# para resolver el EAN al nombre real del producto antes de buscar imágenes.
# Desactivar solo si Google bloquea las peticiones de forma persistente.
EAN_ENRICHMENT_ENABLED=true

# ==========================================
# SCRAPER — BÚSQUEDA
# ==========================================
# Número de imágenes a buscar por producto
IMAGES_PER_PRODUCT=5
# Tamaño mínimo aceptable de imagen (px)
IMAGE_MIN_WIDTH=200
IMAGE_MIN_HEIGHT=200
# Tamaño de redimensionado final (px)
IMAGE_RESIZE_WIDTH=800
IMAGE_RESIZE_HEIGHT=800
# Número de workers de descarga simultáneos
DOWNLOAD_WORKERS=4
# Timeout HTTP para descarga de imágenes (segundos)
DOWNLOAD_TIMEOUT=10
 
# ==========================================
# ALMACENAMIENTO
# ==========================================
# Backend: local | s3 | azure
STORAGE_BACKEND=local
# Directorio raíz (solo si STORAGE_BACKEND=local)
OUTPUT_DIR=imagenes_descargadas
# Tiempo de vida de los archivos de trabajo en segundos (24h por defecto)
FILE_TTL_SECONDS=86400
 
# ── AWS S3 (solo si STORAGE_BACKEND=s3) ──────────────────────────────────────
AWS_S3_BUCKET=
AWS_S3_PREFIX=harvist
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
 
# ── Azure Blob (solo si STORAGE_BACKEND=azure) ───────────────────────────────
AZURE_CONTAINER=
AZURE_BLOB_PREFIX=harvist
AZURE_CONNECTION_STRING=
 
# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=DEBUG               # ERROR | WARN | INFO | DEBUG
LOG_DIR=logs
LOG_ROTATION=100 MB
LOG_RETENTION=7 days
 
# ==========================================
# IA — FASE 5 — Proveedor de IA (opcional)
# ==========================================
# Proveedor: anthropic (Claude, requiere créditos) | groq (gratuito, Llama/Mixtral)
AI_PROVIDER=anthropic

# ── Groq (gratuito) — https://console.groq.com ───────────────────────────────
# Crear cuenta gratuita, obtener API key y pegarla aquí
GROQ_API_KEY=
# Modelo Groq recomendado para descripciones SEO
GROQ_MODEL=llama-3.3-70b-versatile

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Activar generación de descripciones de producto con IA
ENABLE_AI_DESCRIPTIONS=false
# API key de Anthropic — obligatoria si ENABLE_AI_DESCRIPTIONS=true
# Obtener en: https://console.anthropic.com/
CLAUDE_API_KEY=
# Modelo a usar — haiku es el más económico y rápido para descripciones
# Opciones: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001
# Máximo de tokens por descripción generada
CLAUDE_MAX_TOKENS=300
# Timeout en segundos por llamada a la API
CLAUDE_TIMEOUT=30
# Número máximo de reintentos ante errores transitorios
CLAUDE_MAX_RETRIES=3
# Número de productos enviados a Claude por llamada (batch). Más alto = menos llamadas pero respuestas más largas.
CLAUDE_BATCH_SIZE=10
# Tipo de tienda inyectado en el prompt (ej: 'tiendas de mascotas', 'ferreterías', 'tiendas de ropa deportiva')
CLAUDE_STORE_TYPE=tiendas de mascotas
# Ruta a un archivo .txt con plantilla de prompt personalizada.
# Debe contener los placeholders {store_type} y {productos_json}.
# Si está vacío se usa el prompt SEO por defecto.
CLAUDE_PROMPT_FILE=

# ==========================================
# RESOLUCIÓN DE MARCAS — FASE 6
# ==========================================
# URL del proxy rotativo para evitar bloqueos en búsquedas web (opcional)
# Formato: http://user:pass@host:port
ROTATING_PROXY_URL=
# Timeout HTTP para resolución de marcas por EAN (segundos)
BRAND_HTTP_TIMEOUT=10
# Timeout HTTP para extracción de marca desde Amazon.es (segundos)
AMAZON_HTTP_TIMEOUT=10
