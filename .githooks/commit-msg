#!/bin/bash
# @author BenjaminDTS
# Commit-msg hook: elimina líneas de autoría de IA (Claude, Copilot, etc.)

COMMIT_FILE="$1"

# Co-Authored-By de Claude / Anthropic / Copilot
sed -i '/^Co-[Aa]uthored-[Bb]y:.*[Cc]laude/d'    "$COMMIT_FILE"
sed -i '/^Co-[Aa]uthored-[Bb]y:.*[Aa]nthrop/d'   "$COMMIT_FILE"
sed -i '/^Co-[Aa]uthored-[Bb]y:.*[Cc]opilot/d'   "$COMMIT_FILE"
sed -i '/^Co-[Aa]uthored-[Bb]y:.*noreply@/d'      "$COMMIT_FILE"

# Líneas "Creado por" / "Generated with"
sed -i '/^Creado por:.*[Cc]laude/d'                "$COMMIT_FILE"
sed -i '/^Creado por:.*[Cc]opilot/d'               "$COMMIT_FILE"
sed -i '/🤖.*[Cc]laude/d'                          "$COMMIT_FILE"
sed -i '/🤖.*[Gg]enerated/d'                       "$COMMIT_FILE"

# Trailing blank lines al final del archivo
sed -i -e :a -e '/^\s*$/{$d;N;ba}' "$COMMIT_FILE"
